# Copy this file to .env and fill in your values
# Vite exposes vars prefixed with VITE_ to the browser

# Razorpay (get from https://dashboard.razorpay.com)
VITE_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx

# Site URL (used for OG tags, sitemaps, etc.)
VITE_SITE_URL=https://namapharma.com

# WhatsApp number for the floating button (digits only, with country code)
VITE_WHATSAPP_NUMBER=919876543210
